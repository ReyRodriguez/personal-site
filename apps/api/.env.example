# Copy to apps/api/.env and adjust. Never commit the real .env.

# PostgreSQL connection (matches docker-compose.yml service defaults).
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_blog?schema=public"

# API server port.
PORT=3000

# Web origin allowed by CORS (the Angular app).
WEB_ORIGIN="http://localhost:4200"

# JWT signing secret — generate a long random string for production.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"

# Seed-only admin credentials. `prisma:seed` upserts this user (password is
# bcrypt-hashed at seed time). Change these before seeding a real environment.
ADMIN_EMAIL="admin@portfolio.local"
ADMIN_PASSWORD="change-me"
