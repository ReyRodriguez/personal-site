# Production env for the API — copy to /srv/portfolio/apps/api/.env on the droplet.
# NestJS ConfigModule loads this file (cwd-relative) at runtime. Never commit the real .env.

# Local Postgres on the droplet (loopback only). Use a strong password.
DATABASE_URL="postgresql://portfolio:CHANGE_ME_STRONG@127.0.0.1:5432/portfolio_blog?schema=public"

# Marks the environment as production -> the auth cookie is set Secure (HTTPS only).
NODE_ENV=production
PORT=3000

# Public site origin, used for CORS. Same origin as the SSR app (single domain).
WEB_ORIGIN="https://yourdomain.com"

# 64+ random chars, e.g. `openssl rand -hex 48`.
JWT_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"
JWT_EXPIRES_IN="12h"

# Seed-only. Used once by `prisma:seed` to create the admin user (bcrypt-hashed).
ADMIN_EMAIL="you@yourdomain.com"
ADMIN_PASSWORD="CHANGE_ME_STRONG_ADMIN_PASSWORD"
